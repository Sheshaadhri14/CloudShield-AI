{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "datapipeline:CreatePipeline",
          "datapipeline:ActivatePipeline",
          "iam:PassRole"
        ],
        "Resource": "*",
        "Condition": {
          "DateGreaterThan": {
            "aws:CurrentTime": "2024-01-01T00:00:00Z"
          },
          "DateLessThan": {
            "aws:CurrentTime": "2026-12-31T23:59:59Z"
          }
        }
      },
      {
        "Effect": "Deny",
        "Action": [
          "iam:Delete*"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "condition_rich",
    "risk_label": 2,
    "source_type": "synthetic",
    "attached_to": [
      "user-968",
      "user-237",
      "role-758",
      "role-328"
    ]
  }
}