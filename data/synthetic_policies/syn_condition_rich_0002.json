{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Resource": "arn:aws:s3:::app-bucket-0049/*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          },
          "StringEquals": {
            "aws:PrincipalOrgID": "o-exampleorgid11"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "condition_rich",
    "risk_label": 0,
    "source_type": "synthetic",
    "attached_to": [
      "user-505",
      "user-793",
      "role-201",
      "role-560"
    ]
  }
}