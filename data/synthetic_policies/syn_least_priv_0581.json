        ],
        "Resource": [
          "arn:aws:s3:::app-bucket-0038",
          "arn:aws:s3:::app-bucket-0038/*"
        ],
        "Condition": {
          "StringEquals": {
            "aws:PrincipalOrgID": "o-exampleorgid11"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "least_privilege_low",
    "risk_label": 0,
    "source_type": "synthetic",
    "attached_to": [
      "user-333",
      "role-110",
      "role-044"
    ]
  }
}