{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Resource": [
          "arn:aws:s3:::app-bucket-0006",
          "arn:aws:s3:::app-bucket-0006/*"
        ],
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          },
          "IpAddress": {
            "aws:SourceIp": [
              "10.3.0.0/16"
            ]
          },
          "DateGreaterThan": {
            "aws:CurrentTime": "2024-01-01T00:00:00Z"
          },
          "DateLessThan": {
            "aws:CurrentTime": "2026-12-31T23:59:59Z"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "least_privilege_low",
    "risk_label": 0,
    "source_type": "synthetic",
    "attached_to": [
      "user-737",
      "role-762",
      "role-818"
    ]
  }
}