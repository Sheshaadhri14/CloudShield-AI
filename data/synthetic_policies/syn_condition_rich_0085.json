{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "s3:*",
          "cloudwatch:*"
        ],
        "Resource": "*",
        "Condition": {
          "DateGreaterThan": {
            "aws:CurrentTime": "2024-01-01T00:00:00Z"
          },
          "DateLessThan": {
            "aws:CurrentTime": "2026-12-31T23:59:59Z"
          },
          "StringEquals": {
            "aws:PrincipalOrgID": "o-exampleorgid11"
          }
        }
      },
      {
        "Effect": "Deny",
        "Action": [
          "iam:Delete*"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "condition_rich",
    "risk_label": 1,
    "source_type": "synthetic",
    "attached_to": [
      "user-214",
      "user-902",
      "role-241",
      "role-776"
    ]
  }
}