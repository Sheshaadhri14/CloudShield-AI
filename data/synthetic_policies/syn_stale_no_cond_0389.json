{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "secretsmanager:List*",
          "secretsmanager:Get*",
          "secretsmanager:Describe*"
        ],
        "Resource": "*",
        "Condition": {
          "IpAddress": {
            "aws:SourceIp": [
              "10.12.0.0/16"
            ]
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "stale_no_condition",
    "risk_label": 1,
    "source_type": "synthetic",
    "attached_to": [
      "user-504",
      "role-107"
    ]
  }
}