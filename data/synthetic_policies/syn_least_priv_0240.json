{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Resource": [
          "arn:aws:s3:::app-bucket-0049",
          "arn:aws:s3:::app-bucket-0049/*"
        ],
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "least_privilege_low",
    "risk_label": 0,
    "source_type": "synthetic",
    "attached_to": [
      "user-570",
      "role-715",
      "role-513"
    ]
  }
}