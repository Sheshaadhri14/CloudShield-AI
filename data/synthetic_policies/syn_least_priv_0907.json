{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Resource": [
          "arn:aws:s3:::app-bucket-0024",
          "arn:aws:s3:::app-bucket-0024/*"
        ],
        "Condition": {
          "StringEquals": {
            "aws:PrincipalOrgID": "o-exampleorgid11"
          },
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "least_privilege_low",
    "risk_label": 0,
    "source_type": "synthetic",
    "attached_to": [
      "user-700",
      "role-423",
      "role-079"
    ]
  }
}