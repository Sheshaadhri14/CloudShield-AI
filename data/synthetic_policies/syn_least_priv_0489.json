{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "cloudwatch:GetMetricStatistics",
          "cloudwatch:ListMetrics"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          },
          "StringEquals": {
            "aws:PrincipalOrgID": "o-exampleorgid11"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "least_privilege_low",
    "risk_label": 0,
    "source_type": "synthetic",
    "attached_to": [
      "user-976",
      "role-316",
      "role-787"
    ]
  }
}