{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "ecs:*",
          "cloudwatch:*"
        ],
        "Resource": "*",
        "Condition": {
          "IpAddress": {
            "aws:SourceIp": [
              "10.88.0.0/16"
            ]
          },
          "DateGreaterThan": {
            "aws:CurrentTime": "2024-01-01T00:00:00Z"
          },
          "DateLessThan": {
            "aws:CurrentTime": "2026-12-31T23:59:59Z"
          }
        }
      },
      {
        "Effect": "Deny",
        "Action": [
          "iam:Delete*"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "condition_rich",
    "risk_label": 1,
    "source_type": "synthetic",
    "attached_to": [
      "user-521",
      "user-273",
      "role-408",
      "role-494"
    ]
  }
}