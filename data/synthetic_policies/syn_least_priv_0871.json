{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "cloudwatch:GetMetricStatistics",
          "cloudwatch:ListMetrics"
        ],
        "Resource": "*",
        "Condition": {
          "StringEquals": {
            "aws:PrincipalOrgID": "o-exampleorgid11"
          },
          "IpAddress": {
            "aws:SourceIp": [
              "10.108.0.0/16"
            ]
          },
          "DateGreaterThan": {
            "aws:CurrentTime": "2024-01-01T00:00:00Z"
          },
          "DateLessThan": {
            "aws:CurrentTime": "2026-12-31T23:59:59Z"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "least_privilege_low",
    "risk_label": 0,
    "source_type": "synthetic",
    "attached_to": [
      "user-747",
      "role-232",
      "role-495"
    ]
  }
}