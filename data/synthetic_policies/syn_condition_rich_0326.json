{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "logs:DescribeLogGroups",
          "logs:GetLogEvents"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          },
          "IpAddress": {
            "aws:SourceIp": [
              "10.101.0.0/16"
            ]
          },
          "StringEquals": {
            "aws:PrincipalOrgID": "o-exampleorgid11"
          },
          "DateGreaterThan": {
            "aws:CurrentTime": "2024-01-01T00:00:00Z"
          },
          "DateLessThan": {
            "aws:CurrentTime": "2026-12-31T23:59:59Z"
          }
        }
      },
      {
        "Effect": "Deny",
        "Action": [
          "iam:Delete*"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "condition_rich",
    "risk_label": 0,
    "source_type": "synthetic",
    "attached_to": [
      "user-096",
      "user-118",
      "role-267",
      "role-714"
    ]
  }
}