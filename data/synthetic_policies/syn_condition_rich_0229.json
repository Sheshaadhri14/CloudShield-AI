{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "sagemaker:CreateNotebookInstance",
          "iam:PassRole"
        ],
        "Resource": "*",
        "Condition": {
          "StringEquals": {
            "aws:PrincipalOrgID": "o-exampleorgid11"
          }
        }
      },
      {
        "Effect": "Deny",
        "Action": [
          "iam:Delete*"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "source": "synthetic",
    "scenario": "condition_rich",
    "risk_label": 2,
    "source_type": "synthetic",
    "attached_to": [
      "user-985",
      "user-305",
      "role-507",
      "role-676"
    ]
  }
}