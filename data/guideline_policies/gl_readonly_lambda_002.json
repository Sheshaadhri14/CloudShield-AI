{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "LAMBDAReadOnly2",
        "Effect": "Allow",
        "Action": [
          "lambda:ListFunctions",
          "lambda:GetFunction",
          "lambda:GetPolicy"
        ],
        "Resource": "arn:aws:lambda::516497117841:*",
        "Condition": {
          "StringEquals": {
            "aws:PrincipalOrgID": "o-example0001"
          },
          "IpAddress": {
            "aws:SourceIp": "10.163.0.0/16"
          },
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Least-privilege read-only for lambda",
    "guideline": "AWS Security Best Practice: Grant Least Privilege",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-095"
    ]
  }
}