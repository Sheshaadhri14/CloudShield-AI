{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "SECRETSMANAGERWrite2",
        "Effect": "Allow",
        "Action": [
          "secretsmanager:PutSecretValue",
          "secretsmanager:UpdateSecret"
        ],
        "Resource": "arn:aws:secretsmanager::516497117841:*"
      },
      {
        "Sid": "DenyNonSSL",
        "Effect": "Deny",
        "Action": [
          "secretsmanager:PutSecretValue",
          "secretsmanager:UpdateSecret"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:SecureTransport": "false"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 1,
    "description": "Scoped write for secretsmanager with SSL deny",
    "guideline": "AWS Well-Architected: Protect data in transit",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-025"
    ]
  }
}