{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "S3Write1",
        "Effect": "Allow",
        "Action": [
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:PutObjectAcl"
        ],
        "Resource": "arn:aws:s3:::write-bucket-001/*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      },
      {
        "Sid": "DenyNonSSL",
        "Effect": "Deny",
        "Action": [
          "s3:PutObject",
          "s3:DeleteObject",
          "s3:PutObjectAcl"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:SecureTransport": "false"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Scoped write for s3 with SSL deny",
    "guideline": "AWS Well-Architected: Protect data in transit",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-027"
    ]
  }
}