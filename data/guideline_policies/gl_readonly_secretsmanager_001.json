{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "SECRETSMANAGERReadOnly1",
        "Effect": "Allow",
        "Action": [
          "secretsmanager:GetSecretValue",
          "secretsmanager:DescribeSecret",
          "secretsmanager:ListSecrets"
        ],
        "Resource": "arn:aws:secretsmanager::680564837142:*",
        "Condition": {
          "StringEquals": {
            "aws:PrincipalOrgID": "o-example0001"
          },
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Least-privilege read-only for secretsmanager",
    "guideline": "AWS Security Best Practice: Grant Least Privilege",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-016"
    ]
  }
}