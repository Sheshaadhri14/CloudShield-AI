{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "IAMReadOnly2",
        "Effect": "Allow",
        "Action": [
          "iam:GetUser",
          "iam:GetRole",
          "iam:ListRoles",
          "iam:ListUsers",
          "iam:ListPolicies",
          "iam:GetPolicy"
        ],
        "Resource": "arn:aws:iam::516497117841:*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          },
          "StringEquals": {
            "aws:PrincipalOrgID": "o-example0001"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Least-privilege read-only for iam",
    "guideline": "AWS Security Best Practice: Grant Least Privilege",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-074"
    ]
  }
}