{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "EC2Write2",
        "Effect": "Allow",
        "Action": [
          "ec2:RunInstances",
          "ec2:TerminateInstances",
          "ec2:StartInstances",
          "ec2:StopInstances",
          "ec2:RebootInstances"
        ],
        "Resource": "arn:aws:ec2::516894374970:*"
      },
      {
        "Sid": "DenyNonSSL",
        "Effect": "Deny",
        "Action": [
          "ec2:RunInstances",
          "ec2:TerminateInstances",
          "ec2:StartInstances",
          "ec2:StopInstances",
          "ec2:RebootInstances"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:SecureTransport": "false"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 1,
    "description": "Scoped write for ec2 with SSL deny",
    "guideline": "AWS Well-Architected: Protect data in transit",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-025"
    ]
  }
}