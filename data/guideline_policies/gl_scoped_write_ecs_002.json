{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "ECSWrite2",
        "Effect": "Allow",
        "Action": [
          "ecs:RunTask",
          "ecs:StopTask",
          "ecs:UpdateService"
        ],
        "Resource": "arn:aws:ecs::680564837142:*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      },
      {
        "Sid": "DenyNonSSL",
        "Effect": "Deny",
        "Action": [
          "ecs:RunTask",
          "ecs:StopTask",
          "ecs:UpdateService"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:SecureTransport": "false"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Scoped write for ecs with SSL deny",
    "guideline": "AWS Well-Architected: Protect data in transit",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-097"
    ]
  }
}