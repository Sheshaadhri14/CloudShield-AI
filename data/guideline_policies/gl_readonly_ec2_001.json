{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "EC2ReadOnly1",
        "Effect": "Allow",
        "Action": [
          "ec2:DescribeInstances",
          "ec2:DescribeVpcs",
          "ec2:DescribeSecurityGroups",
          "ec2:DescribeSubnets",
          "ec2:DescribeImages"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:SecureTransport": "true"
          },
          "StringEquals": {
            "aws:PrincipalOrgID": "o-example0001"
          },
          "IpAddress": {
            "aws:SourceIp": "10.204.0.0/16"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Least-privilege read-only for ec2",
    "guideline": "AWS Security Best Practice: Grant Least Privilege",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-089"
    ]
  }
}