{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "RDSReadOnly0",
        "Effect": "Allow",
        "Action": [
          "rds:DescribeDBInstances",
          "rds:DescribeDBClusters",
          "rds:ListTagsForResource"
        ],
        "Resource": "*",
        "Condition": {
          "IpAddress": {
            "aws:SourceIp": "10.171.0.0/16"
          },
          "Bool": {
            "aws:SecureTransport": "true",
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Least-privilege read-only for rds",
    "guideline": "AWS Security Best Practice: Grant Least Privilege",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-030"
    ]
  }
}