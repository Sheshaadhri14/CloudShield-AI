{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "SQSReadOnly4",
        "Effect": "Allow",
        "Action": [
          "sqs:GetQueueAttributes",
          "sqs:ListQueues",
          "sqs:GetQueueUrl"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:SecureTransport": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Least-privilege read-only for sqs",
    "guideline": "AWS Security Best Practice: Grant Least Privilege",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-001"
    ]
  }
}