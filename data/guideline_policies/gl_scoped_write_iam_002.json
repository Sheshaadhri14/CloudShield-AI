{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "IAMWrite2",
        "Effect": "Allow",
        "Action": [
          "iam:CreateUser",
          "iam:DeleteUser",
          "iam:UpdateUser",
          "iam:AttachUserPolicy",
          "iam:DetachUserPolicy"
        ],
        "Resource": "arn:aws:iam::209095918079:*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      },
      {
        "Sid": "DenyNonSSL",
        "Effect": "Deny",
        "Action": [
          "iam:CreateUser",
          "iam:DeleteUser",
          "iam:UpdateUser",
          "iam:AttachUserPolicy",
          "iam:DetachUserPolicy"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:SecureTransport": "false"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Scoped write for iam with SSL deny",
    "guideline": "AWS Well-Architected: Protect data in transit",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-023"
    ]
  }
}