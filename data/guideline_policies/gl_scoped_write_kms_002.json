{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "KMSWrite2",
        "Effect": "Allow",
        "Action": [
          "kms:Encrypt",
          "kms:Decrypt",
          "kms:GenerateDataKey",
          "kms:ReEncrypt*"
        ],
        "Resource": "arn:aws:kms::516534535501:*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      },
      {
        "Sid": "DenyNonSSL",
        "Effect": "Deny",
        "Action": [
          "kms:Encrypt",
          "kms:Decrypt",
          "kms:GenerateDataKey",
          "kms:ReEncrypt*"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:SecureTransport": "false"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Scoped write for kms with SSL deny",
    "guideline": "AWS Well-Architected: Protect data in transit",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-006"
    ]
  }
}