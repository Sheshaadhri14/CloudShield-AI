{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "CondTest13",
        "Effect": "Allow",
        "Action": [
          "dynamodb:GetItem",
          "dynamodb:Query",
          "dynamodb:Scan",
          "dynamodb:DescribeTable",
          "dynamodb:ListTables"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          },
          "IpAddress": {
            "aws:SourceIp": "10.55.0.0/16"
          },
          "StringEquals": {
            "aws:PrincipalOrgID": "o-example0001"
          },
          "DateGreaterThan": {
            "aws:CurrentTime": "2025-01-01T09:00:00Z"
          },
          "DateLessThan": {
            "aws:CurrentTime": "2026-12-31T18:00:00Z"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Condition coverage test: all4",
