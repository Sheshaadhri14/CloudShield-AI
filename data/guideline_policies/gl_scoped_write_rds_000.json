{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "RDSWrite0",
        "Effect": "Allow",
        "Action": [
          "rds:StartDBInstance",
          "rds:StopDBInstance",
          "rds:ModifyDBInstance"
        ],
        "Resource": "arn:aws:rds::516534535501:*",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true"
          }
        }
      },
      {
        "Sid": "DenyNonSSL",
        "Effect": "Deny",
        "Action": [
          "rds:StartDBInstance",
          "rds:StopDBInstance",
          "rds:ModifyDBInstance"
        ],
        "Resource": "*",
        "Condition": {
          "Bool": {
            "aws:SecureTransport": "false"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Scoped write for rds with SSL deny",
    "guideline": "AWS Well-Architected: Protect data in transit",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-076"
    ]
  }
}