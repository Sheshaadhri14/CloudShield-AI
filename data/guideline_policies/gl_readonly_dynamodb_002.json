{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "DYNAMODBReadOnly2",
        "Effect": "Allow",
        "Action": [
          "dynamodb:GetItem",
          "dynamodb:Query",
          "dynamodb:Scan",
          "dynamodb:DescribeTable",
          "dynamodb:ListTables"
        ],
        "Resource": "arn:aws:dynamodb:us-east-1:516894374970:table/app-table-2",
        "Condition": {
          "Bool": {
            "aws:MultiFactorAuthPresent": "true",
            "aws:SecureTransport": "true"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Least-privilege read-only for dynamodb",
    "guideline": "AWS Security Best Practice: Grant Least Privilege",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-040"
    ]
  }
}