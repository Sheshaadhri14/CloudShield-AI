{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "KMSReadOnly3",
        "Effect": "Allow",
        "Action": [
          "kms:DescribeKey",
          "kms:GetKeyPolicy",
          "kms:ListKeys"
        ],
        "Resource": "arn:aws:kms::516534535501:*",
        "Condition": {
          "IpAddress": {
            "aws:SourceIp": "10.50.0.0/16"
          },
          "StringEquals": {
            "aws:PrincipalOrgID": "o-example0001"
          }
        }
      }
    ]
  },
  "metadata": {
    "risk_label": 0,
    "description": "Least-privilege read-only for kms",
    "guideline": "AWS Security Best Practice: Grant Least Privilege",
    "source": "aws_guideline_generator",
    "source_type": "guideline-based",
    "attached_to": [
      "role-085"
    ]
  }
}