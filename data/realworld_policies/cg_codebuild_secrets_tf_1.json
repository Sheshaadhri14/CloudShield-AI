{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "solo",
      "Effect": "Allow",
      "Action": [
        "s3:ListAllMyBuckets",
        "ssm:DescribeParameters",
        "ssm:GetParameter",
        "codebuild:ListProjects",
        "codebuild:BatchGetProjects",
        "codebuild:ListBuilds",
        "ec2:DescribeInstances",
        "ec2:DescribeVpcs",
        "ec2:DescribeSubnets",
        "ec2:DescribeSecurityGroups"
      ],
      "Resource": "*"
    }
  ]
}